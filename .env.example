# AI runtime. In production, keep provider keys in Cloudflare secrets, not vars.
OPENAI_API_KEY=
CLOUDFLARE_AI_GATEWAY_TOKEN=
CLOUDFLARE_AI_GATEWAY_BASE_URL=
CLOUDFLARE_AI_GATEWAY_BYOK_ALIAS=
OPENAI_MODEL=gpt-5
OPENAI_FAST_MODEL=gpt-5-mini
OPENAI_REASONING_MODEL=gpt-5
OPENAI_STRUCTURED_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Auth runtime.
AUTH_SECRET=
NEXTAUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
ADMIN_EMAILS=
CRON_SECRET=

# Runtime quotas and memory limits for local preview/dev.
RATE_LIMIT_USER_CHAT_DAILY=150
RATE_LIMIT_GUEST_SESSION_DAILY=10
RATE_LIMIT_GUEST_FINGERPRINT_DAILY=10
RATE_LIMIT_GUEST_IP_DAILY=150
RATE_LIMIT_ACTIVITY_DAILY=150
RATE_LIMIT_MEMORY_DAILY=60
LLM_GLOBAL_DAILY_CALL_LIMIT=1000
MEMORY_POST_TURN_SYNTHESIS_THRESHOLD=3
MEMORY_PROFILE_COMPILE_LIMIT=2
APP_WRITE_FREEZE=0
APP_WRITE_FREEZE_RETRY_AFTER_SECONDS=300

# Local URLs.
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
PLAYWRIGHT_BASE_URL=http://localhost:8787

# Optional E2E credentials. Do not commit real values.
E2E_GOOGLE_EMAIL=
E2E_GOOGLE_PASSWORD=
E2E_GOOGLE_IS_ADMIN=0
E2E_TEST_AUTH_SECRET=
E2E_TEST_AUTH_EMAIL=
