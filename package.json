{
  "name": "inspirlearning",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "An AI learning companion that makes learning accessible, personal, and useful for everyone.",
  "homepage": "https://inspirlearning.com",
  "engines": {
    "node": ">=20.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/makriman/inspir.git"
  },
  "bugs": {
    "url": "https://github.com/makriman/inspir/issues"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "cf:build": "tsx scripts/cloudflare/run-sanitized-build.ts opennext-build",
    "cf:preview": "tsx scripts/cloudflare/setup-local-d1.ts && tsx scripts/cloudflare/run-sanitized-build.ts wrangler-preview",
    "cf:preview:remote": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:preview:remote",
    "cf:test:e2e:preview": "tsx scripts/cloudflare/run-preview-playwright.ts",
    "cf:accept:fresh-boundary": "tsx scripts/cloudflare/production-trust-boundary-acceptance.ts",
    "cf:prepare:deploy": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:prepare:deploy",
    "cf:deploy": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:deploy",
    "cf:upload-candidate": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:upload-candidate",
    "cf:stage-candidate": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:stage-candidate",
    "cf:verify:candidate-override": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:candidate-override",
    "cf:activate-candidate": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:activate-candidate",
    "cf:deploy:www-redirect": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:deploy:www-redirect",
    "cf:check:www-redirect": "wrangler deploy --dry-run --config wrangler.www-redirect.jsonc",
    "cf:upload": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:upload",
    "cf:typegen": "wrangler types cloudflare-env.generated.d.ts --include-runtime false --strict-vars false --env-interface CloudflareBindings",
    "cf:typecheck:worker": "wrangler types cloudflare-env.generated.d.ts --include-runtime false --strict-vars false --env-interface CloudflareBindings && tsc --noEmit --project tsconfig.cloudflare-worker.json",
    "cf:verify:local": "tsx scripts/cloudflare/run-local-gates.ts",
    "cf:scan:source-secrets": "tsx scripts/cloudflare/scan-source-secrets.ts",
    "cf:scan:build-artifacts": "tsx scripts/cloudflare/scan-build-artifacts.ts",
    "cf:check:resource-budget": "tsx scripts/cloudflare/check-opennext-resource-budget.ts",
    "cf:materialize:static": "tsx scripts/cloudflare/materialize-static-marketing-assets.ts",
    "cf:harden:backup-permissions": "tsx scripts/cloudflare/harden-backup-permissions.ts",
    "cf:check:write-freeze": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:check:write-freeze",
    "cf:d1:local:setup": "tsx scripts/cloudflare/setup-local-d1.ts",
    "cf:sync:topic-seeds": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:sync:topic-seeds",
    "cf:r2:retire-cache-build": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:r2:retire-cache-build",
    "cf:sync:site-translation-sources": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:sync:site-translation-sources",
    "cf:d1:repair-seo-translations": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:d1:repair-seo-translations",
    "cf:d1:reconcile-staged-translations": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:d1:reconcile-staged-translations",
    "cf:check:d1-migration-budget": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:check:d1-migration-budget",
    "cf:apply:d1-runtime-migrations": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:apply:d1-runtime-migrations",
    "cf:apply:d1-runtime-migration-0017": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:apply:d1-runtime-migration-0017",
    "cf:rollback": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:rollback",
    "cf:resolve:production-maintenance": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:resolve:production-maintenance",
    "cf:verify:d1-runtime-migrations": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:d1-runtime-migrations",
    "cf:verify:d1-runtime-migration-0017": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:d1-runtime-migration-0017",
    "cf:verify:historical-data-preservation": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:historical-data-preservation",
    "cf:verify:historical-data-fresh-0016-preservation": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:historical-data-fresh-0016-preservation",
    "cf:verify:historical-data-continuity": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:historical-data-continuity",
    "cf:cutover:historical-data-fresh-0016": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:cutover:historical-data-fresh-0016",
    "cf:preflight:deploy": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:preflight:deploy",
    "cf:verify:cloudflare-token": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:cloudflare-token",
    "cf:verify:vectorize-readiness": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:vectorize-readiness",
    "cf:verify:production": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:production",
    "cf:verify:authenticated-production": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:authenticated-production",
    "cf:verify:worker-outcomes": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:worker-outcomes",
    "cf:verify:background-outcomes": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:verify:background-outcomes",
    "cf:test:e2e:production": "tsx scripts/cloudflare/run-trust-bound-production-command.ts cf:test:e2e:production",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx scripts/run-release-unit-tests.ts",
    "test:translations:full-completion": "node --import tsx scripts/run-full-translation-completion-tests.ts",
    "test:e2e": "playwright test",
    "doctor": "react-doctor --yes --blocking warning",
    "doctor:json": "tsx scripts/cloudflare/run-react-doctor-gate.ts --report tmp/react-doctor-report.json --output-dir tmp/react-doctor",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "translations:status": "tsx scripts/status-curated-translations.ts",
    "translations:generate-long-tail": "tsx scripts/generate-long-tail-translations.ts",
    "translations:publish-legacy-seed-salvage-acceptance": "tsx scripts/publish-long-tail-seed-salvage-acceptance.ts",
    "translations:test-legacy-seed-salvage": "node --import tsx --test tests/legacy-long-tail-seed-salvage.test.ts",
    "translations:audit-semantic": "tsx scripts/run-translation-semantic-audit.ts",
    "translations:verify-semantic-release": "tsx scripts/translation-semantic-release-attestation.ts",
    "translations:attest-staged-fallback": "tsx scripts/staged-translation-fallback-release-attestation.ts",
    "translations:attest-current-fallback": "tsx scripts/current-translation-fallback-release-attestation.ts --current-no-site-promotion",
    "translations:legacy-marketing-delta": "tsx scripts/run-legacy-marketing-site-delta-release.ts",
    "translations:repair-quality": "tsx scripts/repair-curated-translation-quality.ts",
    "translations:validate-candidates": "tsx scripts/validate-translation-repair-candidates.ts",
    "translations:status-db": "tsx scripts/status-db-translations.ts",
    "translations:export": "tsx scripts/export-curated-translations.ts",
    "translations:export-lexicon": "tsx scripts/export-translation-lexicon.ts",
    "translations:split-lexicon": "tsx scripts/split-translation-lexicon.ts",
    "translations:merge-lexicon": "tsx scripts/merge-translation-lexicon.ts",
    "translations:diagnose-lexicon": "tsx scripts/diagnose-translation-lexicon.ts",
    "translations:build-from-lexicon": "tsx scripts/build-curated-from-lexicon.ts",
    "translations:generate-site-source-manifest": "tsx scripts/generate-site-source-manifest.ts",
    "translations:verify-site-source-manifest": "tsx scripts/verify-site-source-manifest.ts",
    "translations:export-missing": "tsx scripts/export-curated-translations.ts --missing-only",
    "translations:bundle": "tsx scripts/bundle-curated-translations.ts",
    "translations:static-main-app": "tsx scripts/generate-static-main-app-translations.ts",
    "translations:static-main-app:check": "tsx scripts/generate-static-main-app-translations.ts --check",
    "translations:export-cache": "tsx scripts/export-cached-translations.ts",
    "translations:import": "tsx scripts/import-curated-translations.ts",
    "translations:seed-core": "tsx scripts/seed-core-main-app-translations.ts",
    "seo:lastmod:generate": "tsx scripts/seo/generate-sitemap-lastmod.ts",
    "seo:lastmod:check": "tsx scripts/seo/generate-sitemap-lastmod.ts --check",
    "seo:indexnow": "tsx scripts/seo/submit-indexnow.ts"
  },
  "dependencies": {
    "@shadcn/react": "^0.1.0",
    "@speed-highlight/core": "1.2.17",
    "better-auth": "1.6.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "katex": "^0.17.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "miniflare": "4.20260701.0",
    "postcss": "^8.5.15",
    "react-doctor": "^0.5.8",
    "tailwindcss": "3.4.17",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "wrangler": "^4.107.0"
  }
}
