{
  "name": "inspirlearning",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "An AI learning companion that makes learning accessible, personal, and useful for everyone.",
  "homepage": "https://inspirlearning.com",
  "engines": {
    "node": ">=20.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/makriman/inspir.git"
  },
  "bugs": {
    "url": "https://github.com/makriman/inspir/issues"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "cf:build": "tsx scripts/cloudflare/run-sanitized-build.ts opennext-build",
    "cf:preview": "tsx scripts/cloudflare/setup-local-d1.ts && tsx scripts/cloudflare/run-sanitized-build.ts opennext-preview",
    "cf:preview:remote": "tsx scripts/cloudflare/run-sanitized-build.ts opennext-preview --remote",
    "cf:test:e2e:preview": "tsx scripts/cloudflare/run-preview-playwright.ts",
    "cf:deploy": "tsx scripts/cloudflare/run-sanitized-build.ts opennext-deploy",
    "cf:upload": "tsx scripts/cloudflare/run-sanitized-build.ts opennext-upload",
    "cf:typegen": "wrangler types cloudflare-env.generated.d.ts --include-runtime false --strict-vars false --env-interface CloudflareBindings",
    "cf:typecheck:worker": "wrangler types cloudflare-env.generated.d.ts --include-runtime false --strict-vars false --env-interface CloudflareBindings && tsc --noEmit --project tsconfig.cloudflare-worker.json",
    "cf:verify:local": "tsx scripts/cloudflare/run-local-gates.ts",
    "cf:scan:source-secrets": "tsx scripts/cloudflare/scan-source-secrets.ts",
    "cf:scan:build-artifacts": "tsx scripts/cloudflare/scan-build-artifacts.ts",
    "cf:harden:backup-permissions": "tsx scripts/cloudflare/harden-backup-permissions.ts",
    "cf:check:write-freeze": "tsx scripts/cloudflare/check-write-freeze-readiness.ts",
    "cf:activate:write-freeze": "tsx scripts/cloudflare/activate-write-freeze.ts",
    "cf:backup:frozen-cloudflare": "tsx scripts/cloudflare/backup-frozen-cloudflare-production.ts",
    "cf:d1:local:setup": "tsx scripts/cloudflare/setup-local-d1.ts",
    "cf:sync:site-translation-sources": "tsx scripts/cloudflare/sync-site-translation-sources.ts",
    "cf:preflight:deploy": "tsx scripts/cloudflare/deploy-preflight.ts",
    "cf:verify:cloudflare-token": "tsx scripts/cloudflare/verify-cloudflare-api-token.ts",
    "cf:verify:production": "tsx scripts/cloudflare/verify-production.ts",
    "cf:test:e2e:production": "tsx scripts/cloudflare/run-production-playwright.ts",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:e2e": "playwright test",
    "doctor": "npx react-doctor@latest . --yes --blocking warning",
    "doctor:json": "npx react-doctor@latest . --yes --json --json-out tmp/react-doctor-report.json --output-dir tmp/react-doctor",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "translations:status": "tsx scripts/status-curated-translations.ts",
    "translations:status-db": "tsx scripts/status-db-translations.ts",
    "translations:export": "tsx scripts/export-curated-translations.ts",
    "translations:export-lexicon": "tsx scripts/export-translation-lexicon.ts",
    "translations:split-lexicon": "tsx scripts/split-translation-lexicon.ts",
    "translations:merge-lexicon": "tsx scripts/merge-translation-lexicon.ts",
    "translations:diagnose-lexicon": "tsx scripts/diagnose-translation-lexicon.ts",
    "translations:build-from-lexicon": "tsx scripts/build-curated-from-lexicon.ts",
    "translations:generate-site-source-manifest": "tsx scripts/generate-site-source-manifest.ts",
    "translations:export-missing": "tsx scripts/export-curated-translations.ts --missing-only",
    "translations:bundle": "tsx scripts/bundle-curated-translations.ts",
    "translations:export-cache": "tsx scripts/export-cached-translations.ts",
    "translations:import": "tsx scripts/import-curated-translations.ts",
    "translations:seed-core": "tsx scripts/seed-core-main-app-translations.ts"
  },
  "dependencies": {
    "@shadcn/react": "^0.1.0",
    "@speed-highlight/core": "1.2.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "katex": "^0.17.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.15",
    "tailwindcss": "3.4.17",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "wrangler": "^4.102.0"
  }
}
