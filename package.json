{
  "name": "inspirlearning",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "An AI learning companion that makes learning accessible, personal, and useful for everyone.",
  "homepage": "https://inspirlearning.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/makriman/inspir.git"
  },
  "bugs": {
    "url": "https://github.com/makriman/inspir/issues"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "translations:warm": "tsx scripts/warm-main-app-translations.ts",
    "import:bubble": "tsx scripts/import-bubble.ts --mode=best-effort",
    "validate:import": "tsx scripts/validate-import.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.65",
    "@auth/drizzle-adapter": "^1.11.2",
    "@neondatabase/serverless": "^1.1.0",
    "ai": "^6.0.191",
    "drizzle-orm": "^0.45.2",
    "katex": "^0.17.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "3.4.17",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
