{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "inspirlearning",
  "main": "./cloudflare-worker.ts",
  "compatibility_date": "2026-07-08",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "account_id": "a1e5e542dc1d5fe5a5c6b2a10d755a81",
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
    "html_handling": "drop-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": ["/api/guest-chat", "/api/health"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.02,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 0.05,
      "invocation_logs": true,
      "persist": true
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 0.02,
      "persist": true
    }
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "inspirlearning"
    }
  ],
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "NEXT_CACHE_DO_QUEUE",
        "class_name": "DOQueueHandler"
      }
    ]
  },
  "migrations": [
    {
      "tag": "opennext-cache-queue-v1",
      "new_sqlite_classes": ["DOQueueHandler"]
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "inspirlearning-prod",
      "database_id": "7cb2ddf7-ca3d-4f46-a022-cc8b3a25b7b9"
    }
  ],
  "routes": [
    {
      "pattern": "inspirlearning.com",
      "custom_domain": true
    },
    {
      "pattern": "www.inspirlearning.com",
      "custom_domain": true
    }
  ],
  "vars": {
    "CLOUDFLARE_AI_GATEWAY_BASE_URL": "https://gateway.ai.cloudflare.com/v1/a1e5e542dc1d5fe5a5c6b2a10d755a81/inspir/openai",
    "CLOUDFLARE_AI_GATEWAY_BYOK_ALIAS": "inspir",
    "OPENAI_MODEL": "gpt-5-mini",
    "OPENAI_FAST_MODEL": "gpt-5-mini",
    "OPENAI_REASONING_MODEL": "gpt-5-mini",
    "OPENAI_STRUCTURED_MODEL": "gpt-5-mini",
    "RATE_LIMIT_GUEST_SESSION_DAILY": "10",
    "RATE_LIMIT_GUEST_FINGERPRINT_DAILY": "10",
    "RATE_LIMIT_GUEST_IP_DAILY": "150",
    "LLM_GLOBAL_DAILY_CALL_LIMIT": "1000",
    "OBSERVABILITY_INCIDENT_MODE": "0",
    "APP_WRITE_FREEZE": "0",
    "APP_WRITE_FREEZE_RETRY_AFTER_SECONDS": "300"
  },
  "secrets": {
    "required": ["CLOUDFLARE_AI_GATEWAY_TOKEN"]
  }
}
