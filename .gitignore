# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/.playwright/
/.wrangler/
/.wrangler.preview.local.jsonc

# next.js
/.next/
/out/
/.open-next/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
tmp/

# local backups and generated reports
/backups/
/inspirlearning-local-backups/

# env files
.env
.env.*
!.env.example

# local data workbench
data/raw/*.csv
translations/curated/*
!translations/curated/*/
translations/curated/*/*
# The four bootstrap languages carry the complete audited site corpus. They
# are release inputs and must be reproducible from a clean checkout.
!translations/curated/ar/*.json
!translations/curated/hi/*.json
!translations/curated/ml/*.json
!translations/curated/es/*.json
# Main-app editing packs stay local; the compact tracked static-main-app corpus
# is the canonical deploy input.
translations/curated/*/main-app.json
translations/curated/*/main-app.part-*.json
# Other languages publish only the globally materialized Free-plan surfaces.
!translations/curated/*/marketing-shell.json
!translations/curated/*/marketing-shell.part-*.json
!translations/curated/*/route__home.json
!translations/curated/*/route__home.part-*.json
!translations/curated/*/route__mission.json
!translations/curated/*/route__mission.part-*.json
translations/curated-bundles/
translations/workbench/
translations/workbench-site-batch/
translations/workbench-home-current/

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
.dev.vars*
cloudflare-env.generated*.d.ts
