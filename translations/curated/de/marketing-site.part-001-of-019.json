      "value": "\"Eine Arbeit über Urbanisierung planen\""
    },
    {
      "key": "site.ae7bf0f5e95e35def2",
      "source": "\"Plan a science fair project\"",
      "value": "\"Ein Projekt für die Wissenschaftsmesse planen\""
    },
    {
      "key": "site.beb1a3990468994fa5",
      "source": "\"Plan my week for math\"",
      "value": "\"Meine Woche für Mathe planen\""
    },
    {
      "key": "site.27231b246e17d0c2c9",
      "source": "\"Practice coding every day\"",
      "value": "\"Jeden Tag Programmieren üben\""
    },
    {
      "key": "site.4d3668460816b055d6",
      "source": "\"Practice internship questions\"",
      "value": "\"Praktikumsfragen üben\""
    },
    {
      "key": "site.b1be6a59a253cd379f",
      "source": "\"Practice my school presentation\"",
      "value": "\"Meine Schulpräsentation üben\""
    },
    {
      "key": "site.a24cb767e714361928",
      "source": "\"Practice my science project viva\"",
      "value": "\"Meine mündliche Prüfung zum Wissenschaftsprojekt üben\""
    },
    {
      "key": "site.2f2c51a5709bb64598",
      "source": "\"Quiz me on this topic and wait for my answer.\"",
      "value": "\"Frag mich zu diesem Thema ab und warte auf meine Antwort.\""
    },
    {
      "key": "site.6fcc592a986e292fca",
      "source": "\"Quiz me on vocabulary again\"",
      "value": "\"Frag mich noch einmal Vokabeln ab\""
    },
    {
      "key": "site.3acc3b61f31d686446",
      "source": "\"Read 20 minutes daily\"",
      "value": "\"Täglich 20 Minuten lesen\""
    },
    {
      "key": "site.bb2f09596aacbacc01",
      "source": "\"Reflect after a bad test\"",
      "value": "\"Nach einem schlechten Test reflektieren\""
    },
    {
      "key": "site.cfb34a341c7e2d6f6a",
      "source": "\"Remember the planets\"",
      "value": "\"Die Planeten merken\""
    },
    {
      "key": "site.345f32682abe14e0c1",
      "source": "\"Research renewable energy\"",
      "value": "\"Erneuerbare Energien recherchieren\""
    },
    {
      "key": "site.1d3cd60a6d600d99d1",
      "source": "\"Review yesterday's chemistry\"",
      "value": "\"Chemie von gestern wiederholen\""
    },
    {
      "key": "site.04c13dcb1ceef93ffa",
      "source": "\"SAT vocabulary\"",
      "value": "\"SAT-Wortschatz\""
    },
    {
      "key": "site.b5a1fc836e7e1dd3cc",
      "source": "\"Should a company enter this market?\"",
      "value": "\"Sollte ein Unternehmen in diesen Markt eintreten?\""
    },
    {
      "key": "site.8e74b43d40c5800b62",
      "source": "\"Should homework exist?\"",
      "value": "\"Sollte es Hausaufgaben geben?\""
    },
    {
      "key": "site.2bcdb1981436c4f8ab",
      "source": "\"Should lying ever be okay?\"",
      "value": "\"Darf Lügen jemals in Ordnung sein?\""
    },
    {
      "key": "site.9580b3707c6f037e5f",
      "source": "\"Simulate supply and demand\"",
      "value": "\"Angebot und Nachfrage simulieren\""
    },
    {
      "key": "site.747708af741ed9c7ce",
      "source": "\"Solve 2x + 5 = 17 with me\"",
      "value": "\"Löse 2x + 5 = 17 mit mir\""
    },
    {
      "key": "site.e60b4c47eec82cc2e6",
      "source": "\"Space exploration\"",
      "value": "\"Weltraumforschung\""
    },
    {
      "key": "site.0d1f7a8d23af53c8b9",
      "source": "\"Spanish cafe roleplay\"",
      "value": "\"Spanisches Café-Rollenspiel\""
    },
    {
      "key": "site.19cec50da6b8f97695",
      "source": "\"Spot bias in this paragraph\"",
      "value": "\"Voreingenommenheit in diesem Absatz erkennen\""
    },
    {
      "key": "site.7a3e28bcbc3c6bdcea",
      "source": "\"Stop procrastinating on math\"",
      "value": "\"Aufhören, Mathe aufzuschieben\""
    },
    {
      "key": "site.8b901fcccd7f5c092d",
      "source": "\"Story concepts about friendship\"",
      "value": "\"Geschichtenideen über Freundschaft\""
    },
    {
      "key": "site.243097e559c79594c0",
      "source": "\"Summarize chapter 2\"",
      "value": "\"Kapitel 2 zusammenfassen\""
    },
    {
      "key": "site.ef901899abb3a4ee04",
      "source": "\"Talk to Cleopatra\"",
      "value": "\"Mit Kleopatra sprechen\""
    },
    {
      "key": "site.2b09c9c5ce69aea86f",
      "source": "\"Teach fractions as a story\"",
      "value": "\"Brüche als Geschichte erklären\""
    },
    {
      "key": "site.e4b0dfd184f87b629c",
      "source": "\"Teach me financial modeling\"",
      "value": "\"Lehre mich Finanzmodellierung\""
    },
    {
      "key": "site.94b3bf363830f217a7",
      "source": "\"Teach me how interest works\"",
      "value": "\"Erkläre mir, wie Zinsen funktionieren\""
    },
    {
      "key": "site.ae10897bb3e0cc0358",
      "source": "\"Teach me Porter's Five Forces\"",
      "value": "\"Lehre mich Porters Five Forces\""
    },
    {
      "key": "site.ceb95d9b3771f88bbf",
      "source": "\"Teach me Python loops\"",
      "value": "\"Lehre mich Python-Schleifen\""
    },
    {
      "key": "site.ea71d2a609fa3e7aa3",
      "source": "\"Teach rhythm basics\"",
      "value": "\"Rhythmus-Grundlagen lehren\""
    },
    {
      "key": "site.4ad90215ccef01e1b6",
      "source": "\"Test my understanding of inflation\"",
      "value": "\"Teste mein Verständnis von Inflation\""
    },
    {
      "key": "site.f7fd15ce0e15c12b54",
      "source": "\"Test whether my argument is valid. Do not give me the answer too quickly.\"",
      "value": "\"Teste, ob mein Argument gültig ist. Gib mir die Antwort nicht zu schnell.\""
    },
    {
      "key": "site.6fa00ff2596761d950",
      "source": "\"Turn this note into Q&A\"",
      "value": "\"Wandle diese Notiz in Fragen und Antworten um\""
    },
    {
      "key": "site.1051be6b464beece78",
      "source": "\"Turn vocabulary into levels\"",
      "value": "\"Vokabeln in Level verwandeln\""
    },
    {
      "key": "site.f220c4da97503ce8a6",
      "source": "\"Use examples from my exam, project, or daily life.\"",
      "value": "\"Nutze Beispiele aus meiner Prüfung, meinem Projekt oder meinem Alltag.\""
    },
    {
      "key": "site.0fee39b01c4876c032",
      "source": "\"What does a court do?\"",
      "value": "\"Was macht ein Gericht?\""
    },
    {
      "key": "site.50384ba38a4b8012fc",
      "source": "\"What does a product manager do?\"",
      "value": "\"Was macht ein Product Manager?\""
    },
    {
      "key": "site.b19f59956b7ce0f5dd",
      "source": "\"What does this survey show?\"",
      "value": "\"Was zeigt diese Umfrage?\""
    },
    {
      "key": "site.8915cb7f610cf00104",
      "source": "\"What happens if taxes change?\"",
      "value": "\"Was passiert, wenn sich Steuern ändern?\""
    },
    {
      "key": "site.9eccd82931b54f0299",
      "source": "\"What happens if we change temperature?\"",
      "value": "\"Was passiert, wenn wir die Temperatur ändern?\""
    },
    {
      "key": "site.4828443322503ae37f",
      "source": "\"What is knowledge?\"",
      "value": "\"Was ist Wissen?\""
    },
    {
      "key": "site.f2b09f82266b48bb18",
      "source": "\"What learning strategy fits me?\"",
      "value": "\"Welche Lernstrategie passt zu mir?\""
    },
    {
      "key": "site.6dce9a90f93d1681aa",
      "source": "\"What makes an argument valid?\"",
      "value": "\"Was macht ein Argument gültig?\""
    },
    {
      "key": "site.499aa89065ec8ba52d",
      "source": "\"What makes something fair?\"",
      "value": "\"Was macht etwas fair?\""
    },
    {
      "key": "site.f65e64f882ddbf963f",
      "source": "\"What misconception would lead someone to my wrong answer?\"",
      "value": "\"Welches Missverständnis könnte zu meiner falschen Antwort geführt haben?\""
    },
    {
      "key": "site.0331d96e554b357433",
      "source": "\"What should I be careful not to romanticize?\"",
      "value": "\"Was sollte ich nicht romantisieren?\""
    },
    {
      "key": "site.899b3a4f182cd48666",
      "source": "\"What were your real options at this moment?\"",
      "value": "\"Welche echten Optionen hatten Sie in diesem Moment?\""
    },
    {
      "key": "site.7b2c08c8c2c07bbe75",
      "source": "\"What would people in your time assume that modern readers might miss?\"",
      "value": "\"Was würden Menschen in Ihrer Zeit voraussetzen, das modernen Leserinnen und Lesern entgehen könnte?\""
    },
    {
      "key": "site.49c4ac4cb169d26b64",
      "source": "\"What would your critics say about your choices?\"",
      "value": "\"Was würden Ihre Kritiker über Ihre Entscheidungen sagen?\""
    },
    {
      "key": "site.8e5f5224537e4b4a28",
      "source": "\"Which parts of your story are well documented?\"",
      "value": "\"Welche Teile Ihrer Geschichte sind gut belegt?\""
    },
    {
      "key": "site.a9a6af3c45e58fb774",
      "source": "\"Why are cities near rivers?\"",
      "value": "\"Warum liegen Städte an Flüssen?\""
    },
    {
      "key": "site.f9a4a57a9a4e349f9d",
      "source": "\"Why did I avoid studying?\"",
      "value": "\"Warum habe ich das Lernen vermieden?\""
    },
    {
      "key": "site.aa81a9ae56371be864",
      "source": "\"Why did the Roman Empire weaken?\"",
      "value": "\"Warum wurde das Römische Reich schwächer?\""
    },
    {
      "key": "site.1ee20afd1412768111",
      "source": "\"Why is my algebra answer wrong?\"",
      "value": "\"Warum ist meine Algebra-Antwort falsch?\""
    },
    {
      "key": "site.256c116ae9b2484bc8",
      "source": "\"Why is this grammar rule weird?\"",
      "value": "\"Warum ist diese Grammatikregel so seltsam?\""
    },
    {
      "key": "site.56cf0215714c00e4a9",
      "source": "\"Words about weather\"",
      "value": "\"Wörter zum Wetter\""
    },
    {
      "key": "site.12b0b373fd8463446f",
      "source": "\"World capitals\"",
      "value": "\"Hauptstädte der Welt\""
