    },
    {
      "key": "component.8fdeb0d69c1c",
      "source": "Local working language with class-appropriate fluency",
      "value": "具备课堂所需流利程度的当地工作语言"
    },
    {
      "key": "component.9e0dc1ca5be9",
      "source": "Lock useful notes only after the idea has been used.",
      "value": "仅在想法被使用后才锁定有用的笔记。"
    },
    {
      "key": "component.26a5f8e6af94",
      "source": "London Bridge approaches",
      "value": "伦敦桥引桥"
    },
    {
      "key": "component.755ee1f449e8",
      "source": "London, 1666",
      "value": "伦敦，1666年"
    },
    {
      "key": "component.a34c905adfc6",
      "source": "long run",
      "value": "长期"
    },
    {
      "key": "component.57b66b21cdcf",
      "source": "Look for the causal link. Which variable actually changed, and what does it affect next?",
      "value": "寻找因果联系。哪个变量发生了实际变化，它接下来会影响什么？"
    },
    {
      "key": "component.42e09520a427",
      "source": "Low to moderate",
      "value": "低至中等"
    },
    {
      "key": "component.623138553af0",
      "source": "Make it smaller",
      "value": "使其更小"
    },
    {
      "key": "component.23d86dc363a2",
      "source": "Make it stranger",
      "value": "使其更陌生"
    },
    {
      "key": "component.9fcd273d22b4",
      "source": "Make the first rough structure before giving advice. Start with: \"I made the first rough structure. Edit anything. I will react to your changes.\"",
      "value": "在提供建议之前先做出初步结构。以这句话开头：“我已经做出了初步结构。请进行编辑。我会对你的修改做出反应。”"
    },
    {
      "key": "component.7e89eb301168",
      "source": "Manipulation proves you can use the model, not just repeat it.",
      "value": "操作证明你可以使用该模型，而不仅仅是重复它。"
    },
    {
      "key": "component.87fce8797643",
      "source": "Map allies, enemies, critics, patrons, and pressure groups around this person at this moment.",
      "value": "绘制此人此时身边的盟友、敌人、批评者、赞助人和压力团体。"
    },
    {
      "key": "component.08eed886b309",
      "source": "Mapping the answer",
      "value": "绘制答案图谱"
    },
    {
      "key": "component.8c594c51cea4",
      "source": "Market characters are composites",
      "value": "市场角色是复合体"
    },
    {
      "key": "component.84dfe5c68167",
      "source": "Market inspector",
      "value": "市场检查员"
    },
    {
      "key": "component.aa63d999a216",
      "source": "Market outside the complex",
      "value": "综合体外的市场"
    },
    {
      "key": "component.586d1f21ed40",
      "source": "Market pressure score",
      "value": "市场压力评分"
    },
    {
      "key": "component.9c2301977a75",
      "source": "Market street near Chandni Chowk during the siege",
      "value": "围城期间月光集市附近的商业街"
    },
    {
      "key": "component.0e62007a52c3",
      "source": "Market woman",
      "value": "市场妇女"
    },
    {
      "key": "component.9e24faa5c9d6",
      "source": "market, household, workshop, port, school, or neighborhood",
      "value": "市场、家庭、作坊、港口、学校或社区"
    },
    {
      "key": "component.3f5d365ccac4",
      "source": "Markets move when incentives change. Demand captures willingness to buy, supply captures willingness to sell, and price is where the pressure balances.",
      "value": "当激励机制改变时，市场就会发生变化。需求体现了购买意愿，供给体现了销售意愿，而价格则是压力平衡点。"
    },
    {
      "key": "component.4855a517bc2a",
      "source": "Markets operate under timed gates",
      "value": "市场在特定时间窗口内运作"
    },
    {
      "key": "component.13cd4e8f71bc",
      "source": "Markets, homes, workshops, courts, maps, and decision points.",
      "value": "市场、家庭、作坊、法庭、地图和决策点。"
    },
    {
      "key": "component.c1b057dab7cd",
      "source": "Mastery = recall + application + feedback + transfer.",
      "value": "精通 = 回忆 + 应用 + 反馈 + 迁移。"
    },
    {
      "key": "component.f3cbc8ff4420",
      "source": "Mastery checkpoint passed",
      "value": "已通过精通检查点"
    },
    {
      "key": "component.7f2cf10b428b",
