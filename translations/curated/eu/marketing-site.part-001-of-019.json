      "value": ", eta noiz ireki inspir."
    },
    {
      "key": "site.b6ad3fa84a3b2c302d",
      "source": "\"AI in classrooms\"",
      "value": "\"AI ikasgeletan\""
    },
    {
      "key": "site.58f18667d1553b180f",
      "source": "\"Animal testing\"",
      "value": "\"Animalien gaineko probak\""
    },
    {
      "key": "site.68eab3d70d42801764",
      "source": "\"Ask a teacher for help\"",
      "value": "\"Eskatu laguntza irakasle bati\""
    },
    {
      "key": "site.677a241f861e70c905",
      "source": "\"Ask Ambedkar about democracy\"",
      "value": "\"Galdetu Ambedkarri demokraziari buruz\""
    },
    {
      "key": "site.5b7b18c94925fe3436",
      "source": "\"Ask me one question that helps me start.\"",
      "value": "\"Egin iezadazu hasteko lagunduko didan galdera bat.\""
    },
    {
      "key": "site.4f34371e7efcd579c6",
      "source": "\"Ask me questions about this poem\"",
      "value": "\"Egin iezazkidazu galderak poema honi buruz\""
    },
    {
      "key": "site.fbd0875be91d12ed1f",
      "source": "\"Ask me questions before explaining too much.\"",
      "value": "\"Egin iezazkidazu galderak gehiegi azaldu aurretik.\""
    },
    {
      "key": "site.6312682a8b947bbb86",
      "source": "\"Ask me thesis defense questions\"",
      "value": "\"Egin iezazkidazu tesi-defentsako galderak\""
    },
    {
      "key": "site.c961b3ecc381d44bae",
      "source": "\"Athens, 399 BCE\"",
      "value": "\"Atenas, K.a. 399\""
    },
    {
      "key": "site.8c62e4c2b93ece06fb",
      "source": "\"Balance school and exam prep\"",
      "value": "\"Orekatu eskola eta azterketetarako prestaketa\""
    },
    {
      "key": "site.ac77f4dd354288c3d1",
      "source": "\"Build a map of democracy\"",
      "value": "\"Eraiki demokraziaren mapa bat\""
    },
    {
      "key": "site.73920bb846f6d098de",
      "source": "\"Build a photosynthesis explanation with me\"",
      "value": "\"Eraiki nirekin fotosintesiaren azalpen bat\""
    },
    {
      "key": "site.913307fec36113d976",
      "source": "\"Build a portfolio website\"",
      "value": "\"Sortu portfolio-webgune bat\""
    },
    {
      "key": "site.8b1d542484ff95582b",
      "source": "\"Business English words\"",
      "value": "\"Negozio-ingeleseko hitzak\""
    },
    {
      "key": "site.60426296153a6d3e6e",
      "source": "\"Business strategy case\"",
      "value": "\"Negozio-estrategiako kasua\""
    },
    {
      "key": "site.89748ee27832bddccb",
      "source": "\"Causes of World War I\"",
      "value": "\"Lehen Mundu Gerraren arrazoiak\""
    },
    {
      "key": "site.9fbeb9a912fa0f74c5",
      "source": "\"Chang'an, 742\"",
      "value": "\"Chang'an, 742\""
    },
    {
      "key": "site.2c2a82b4f1cdf0977f",
      "source": "\"Check my answer before giving yours.\"",
      "value": "\"Egiaztatu nire erantzuna zurea eman aurretik.\""
    },
    {
      "key": "site.f41d6a56bf9f66e73a",
      "source": "\"Check my essay thesis\"",
      "value": "\"Egiaztatu nire idazlanaren tesia\""
    },
    {
      "key": "site.9513861657cf00b23c",
      "source": "\"Check this claim's evidence\"",
      "value": "\"Egiaztatu baieztapen honen frogak\""
    },
    {
      "key": "site.5637d5d3a384f92ca0",
      "source": "\"Compare India and Japan\"",
      "value": "\"Konparatu India eta Japonia\""
    },
    {
      "key": "site.a63a35a2134447a51e",
      "source": "\"Compare law and psychology\"",
      "value": "\"Konparatu zuzenbidea eta psikologia\""
    },
    {
      "key": "site.13a031b3aabee99f2c",
      "source": "\"Compare Renaissance and modern art\"",
      "value": "\"Konparatu Errenazimentua eta arte modernoa\""
    },
    {
      "key": "site.b159be1a7842fcdce2",
      "source": "\"Connect algebra concepts\"",
      "value": "\"Lotu aljebrako kontzeptuak\""
    },
    {
      "key": "site.ea62557f63cd449eb2",
      "source": "\"Create a daily English routine\"",
      "value": "\"Sortu eguneroko ingeles-errutina bat\""
    },
    {
      "key": "site.ddd8530e085a1cc40c",
      "source": "\"Create a math boss battle\"",
      "value": "\"Sortu matematikako boss-borroka bat\""
    },
    {
      "key": "site.e5808a0998239a32b4",
      "source": "\"Create geography flashcards\"",
      "value": "\"Sortu geografiako ikasketa-txartelak\""
    },
    {
      "key": "site.b6d7134a39fc7f7bed",
      "source": "\"Creative presentation openings\"",
      "value": "\"Aurkezpenetarako hasiera sortzaileak\""
    },
    {
      "key": "site.b005e683cf8a4ea608",
      "source": "\"Debate ambition with Steve Jobs\"",
      "value": "\"Eztabaidatu anbizioaz Steve Jobsekin\""
    },
    {
      "key": "site.15771cee6db1d36ab5",
      "source": "\"Debate climate policy with Greta Thunberg\"",
      "value": "\"Eztabaidatu klima-politikaz Greta Thunbergekin\""
    },
    {
      "key": "site.cff31bacfdddabe646",
      "source": "\"Debate justice with Batman\"",
      "value": "\"Eztabaidatu justiziaz Batmanekin\""
    },
    {
      "key": "site.0902d6f9324f9b725f",
      "source": "\"Delhi, 1857\"",
      "value": "\"Delhi, 1857\""
    },
    {
      "key": "site.34cad2f27334889909",
      "source": "\"Design a plant growth experiment\"",
      "value": "\"Diseinatu landareen hazkundeari buruzko esperimentu bat\""
    },
    {
      "key": "site.492bea3c62350d74dd",
      "source": "\"Do not give the final answer yet. Ask me what I think the first step is.\"",
      "value": "\"Ez eman azken erantzuna oraindik. Galdetu zer iruditzen zaidan lehen urratsa.\""
    },
    {
      "key": "site.bb374d9d5a3aae6096",
      "source": "\"Do we have free will?\"",
      "value": "\"Ba al dugu borondate askea?\""
    },
    {
      "key": "site.8b318372e41445ea93",
      "source": "\"Effects of the printing press\"",
      "value": "\"Inprimategiaren ondorioak\""
    },
    {
      "key": "site.45db383cc123dc0a5d",
      "source": "\"Environmental policy case\"",
      "value": "\"Ingurumen-politikako kasua\""
    },
    {
      "key": "site.f71e5e783a0e902ef8",
      "source": "\"Explain acids and bases\"",
      "value": "\"Azaldu azidoak eta baseak\""
    },
    {
      "key": "site.68352370c6b4c5974f",
      "source": "\"Explain black holes simply\"",
      "value": "\"Azaldu zulo beltzak modu errazean\""
    },
    {
      "key": "site.3b30e09413e0f33fdd",
      "source": "\"Explain democracy with characters\"",
      "value": "\"Azaldu demokrazia pertsonaiekin\""
    },
    {
      "key": "site.8290f0b2c5537579ef",
      "source": "\"Explain derivatives step by step\"",
      "value": "\"Azaldu deribatuak pausoz pauso\""
    },
    {
      "key": "site.035fc9b4f97726730f",
      "source": "\"Explain fundamental rights\"",
      "value": "\"Azaldu oinarrizko eskubideak\""
    },
    {
      "key": "site.29df60129de91e2525",
      "source": "\"Explain impressionism\"",
      "value": "\"Azaldu inpresionismoa\""
    },
    {
      "key": "site.aca1528aaeb2cffb88",
      "source": "\"Explain inflation\"",
      "value": "\"Azaldu inflazioa\""
    },
    {
      "key": "site.059ec7ab1fab722a0a",
      "source": "\"Explain major and minor\"",
      "value": "\"Azaldu maiorra eta minorra\""
    },
    {
      "key": "site.c8ea96bbb04cc6b31d",
      "source": "\"Explain recursion in JavaScript\"",
      "value": "\"Azaldu errekurtsioa JavaScript-en\""
    },
    {
      "key": "site.299f96cc2f08e93026",
      "source": "\"Explain this grammar correction\"",
      "value": "\"Azaldu gramatika-zuzenketa hau\""
    },
    {
      "key": "site.df5c61a9942643dbed",
      "source": "\"Explain this table\"",
      "value": "\"Azaldu taula hau\""
    },
    {
      "key": "site.f8b87efd90d4aa1f33",
      "source": "\"Explain why this step works.\"",
      "value": "\"Azaldu zergatik funtzionatzen duen urrats honek.\""
    },
    {
      "key": "site.88df11c3d80e018744",
      "source": "\"Explore the Himalayas\"",
      "value": "\"Arakatu Himalaia\""
    },
    {
      "key": "site.f653326e7c885ed29d",
      "source": "\"Find angles on AI ethics\"",
      "value": "\"Bilatu ikuspegiak AI etikaren inguruan\""
    },
    {
      "key": "site.b981898c8b52156203",
      "source": "\"Florence, 1504\"",
      "value": "\"Florentzia, 1504\""
    },
    {
      "key": "site.46d8811a6ea409e70f",
      "source": "\"French airport conversation\"",
      "value": "\"Frantsesezko aireportuko elkarrizketa\""
    },
    {
      "key": "site.6e260fa2bd0be72927",
      "source": "\"Give me a harder version after I try.\"",
      "value": "\"Eman bertsio zailago bat nik saiatu ondoren.\""
    },
    {
      "key": "site.ae851fff68c130fe90",
      "source": "\"Give me a hint for this physics problem\"",
      "value": "\"Eman pista bat fisikako problema honetarako\""
    },
    {
      "key": "site.f58e37935fc4ff8561",
      "source": "\"Give me a hint, not the final answer.\"",
      "value": "\"Eman pista bat, ez azken erantzuna.\""
    },
    {
      "key": "site.f7008115b23c438192",
      "source": "\"Give me a similar problem after I solve this one.\"",
      "value": "\"Eman antzeko problema bat hau ebatzi ondoren.\""
    },
    {
      "key": "site.9c92e0d9676106e8ab",
      "source": "\"Handle a rude customer\"",
      "value": "\"Kudeatu bezero zakar bat\""
    },
    {
      "key": "site.ac264478e3015736fb",
      "source": "\"Help debug this error\"",
      "value": "\"Lagundu errore hau arazten\""
    },
    {
      "key": "site.8a43dbb6fdb48b75cf",
      "source": "\"Help interpret a graph\"",
      "value": "\"Lagundu grafiko bat interpretatzen\""
    },
    {
      "key": "site.1e22ed7c2248155c96",
      "source": "\"Help me answer interview questions\"",
      "value": "\"Lagundu elkarrizketa-galderak erantzuten\""
    },
    {
      "key": "site.511740a145c2c1bbf5",
      "source": "\"Help me learn supply and demand\"",
      "value": "\"Lagundu eskaintza eta eskaria ikasten\""
    },
    {
      "key": "site.b1b8fffcfa28dcb1a9",
      "source": "\"Help me outline a story\"",
      "value": "\"Lagundu istorio baten eskema egiten\""
    },
    {
      "key": "site.9386b88b775dc70392",
      "source": "\"Help me plan an essay\"",
      "value": "\"Lagundu idazlan bat planifikatzen\""
    },
    {
      "key": "site.b9299eb2a72bb75d60",
      "source": "\"Help me prepare for finals\"",
      "value": "\"Lagundu azken azterketetarako prestatzen\""
    },
    {
      "key": "site.5418fe11c499220291",
      "source": "\"Help me reason through this ethical dilemma without pushing me to a hidden conclusion.\"",
      "value": "\"Lagundu dilema etiko hau arrazoitzen, ezkutuko ondorio batera bultzatu gabe.\""
    },
    {
      "key": "site.1d42dc0bfb9b08e820",
      "source": "\"Help me simplify recursion\"",
      "value": "\"Lagundu errekurtsioa sinplifikatzen\""
    },
    {
      "key": "site.fd2156a47f3ce6d24a",
      "source": "\"Help me start this word problem\"",
      "value": "\"Lagundu hitz-problema hau hasten\""
    },
    {
      "key": "site.352966c547ac088b1a",
      "source": "\"Help me understand opportunity cost by asking one question at a time.\"",
      "value": "\"Lagundu aukera-kostua ulertzen, galdera bat aldi bakoitzean eginez.\""
    },
    {
      "key": "site.c07c3563d224ee41c6",
      "source": "\"Help me understand photosynthesis\"",
      "value": "\"Lagundu fotosintesia ulertzen\""
    },
    {
      "key": "site.1ef8f109a001c4090f",
      "source": "\"Help me understand this paragraph\"",
      "value": "\"Lagundu paragrafo hau ulertzen\""
    },
    {
      "key": "site.efc3c4b9a6a1a9c59c",
      "source": "\"Help with quadratic equations\"",
      "value": "\"Laguntza ekuazio kuadratikoekin\""
    },
    {
      "key": "site.de84d3164266a95960",
      "source": "\"Here is my answer. What misconception does it show?\"",
      "value": "\"Hona nire erantzuna. Zer uste oker erakusten du?\""
    },
    {
      "key": "site.3fab1a21f2336cdc6a",
      "source": "\"Here is my attempt. What is the smallest hint that would help?\"",
      "value": "\"Hona nire saiakera. Zein da lagunduko lidakeen pista txikiena?\""
    },
    {
      "key": "site.8d2e33bb59de553148",
      "source": "\"Hindi market bargaining\"",
      "value": "\"Hindizko merkatu-negoziazioa\""
    },
    {
      "key": "site.19733128351d4e5021",
      "source": "\"How do chords work?\"",
      "value": "\"Nola funtzionatzen dute akordeek?\""
    },
    {
      "key": "site.201cd90ca44b450cd9",
      "source": "\"How do I look at a painting?\"",
      "value": "\"Nola begiratu behar diot margolan bati?\""
    },
